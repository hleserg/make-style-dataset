# Copy to .env and fill in. NEVER commit .env.
# All app settings use the APP_ prefix (see src/projectname/config.py).

APP_ENVIRONMENT=development
APP_DEBUG=false

# --- Sentry (optional; empty DSN disables Sentry) ---
APP_SENTRY_DSN=
APP_SENTRY_ENVIRONMENT=development
APP_SENTRY_RELEASE=
APP_SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Pipeline: workspace + dataset identity ---
APP_WORKSPACE=workspace
APP_TRIGGER_TOKEN=comicstyle
APP_DATASET_REPEATS=10

# --- Pipeline: stage thresholds ---
APP_MIN_PANEL_AREA=10000
APP_PANEL_BORDER=8
APP_MAX_PANELS=12
APP_SPLASH_AREA_RATIO=0.85
APP_DEDUP_HAMMING_DISTANCE=6
APP_MIN_SIDE_PX=512
APP_TARGET_SIDE=1024

# --- Pipeline: Stage 2 (bubbles) detection + masking ---
APP_BUBBLE_MODEL=kitsumed/yolov8m_seg-speech-bubble
APP_BUBBLE_CONFIDENCE=0.5
APP_OCR_LANGUAGES=en
APP_MASK_DILATION_PX=5
APP_MAX_MASK_COVERAGE=0.6
APP_BUBBLES_DEBUG=false

# --- Pipeline: Stage 3 (inpaint) ---
APP_INPAINT_BACKEND=lama

# --- Pipeline: Stage 4 (clean) ---
APP_CLEAN_DENOISE=false

# --- Pipeline: Stage 5 (caption) ---
APP_CAPTION_BACKEND=wd14
APP_CAPTION_THRESHOLD=0.35

# --- Pipeline: stage flags (gate which stages 'run-all' executes) ---
APP_RUN_PANELS=true
APP_RUN_BUBBLES=true
APP_RUN_INPAINT=true
APP_RUN_CLEAN=true
APP_RUN_CAPTION=true
