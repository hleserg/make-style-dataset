# Copy to .env and fill in. NEVER commit .env.
# All app settings use the APP_ prefix (see src/make_style_dataset/config.py).

APP_ENVIRONMENT=development
APP_DEBUG=false

# --- Sentry (optional; empty DSN disables Sentry) ---
APP_SENTRY_DSN=
APP_SENTRY_ENVIRONMENT=development
APP_SENTRY_RELEASE=
APP_SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Pipeline: workspace + dataset identity ---
APP_WORKSPACE=workspace
APP_TRIGGER_TOKEN=comicstyle
APP_DATASET_REPEATS=10

# --- Pipeline: stage thresholds ---
APP_MIN_PANEL_AREA=10000
APP_PANEL_BORDER=8
APP_MAX_PANELS=12
APP_SPLASH_AREA_RATIO=0.85
APP_DEDUP_HAMMING_DISTANCE=6
APP_MIN_SIDE_PX=512
APP_TARGET_SIDE=1024

# --- Pipeline: Stage 2 (bubbles) detection + masking ---
APP_BUBBLE_MODEL=kitsumed/yolov8m_seg-speech-bubble
APP_BUBBLE_CONFIDENCE=0.5
APP_OCR_LANGUAGES=en
APP_MASK_DILATION_PX=5
APP_MAX_MASK_COVERAGE=0.6
APP_BUBBLES_DEBUG=false

# --- Pipeline: Stage 3 (inpaint) ---
APP_INPAINT_BACKEND=lama

# --- Pipeline: Stage 4 (clean) ---
APP_CLEAN_DENOISE=false

# --- Pipeline: Stage 5 (caption) ---
APP_CAPTION_BACKEND=wd14
APP_CAPTION_THRESHOLD=0.35

# --- Local web UI (optional; `make-style-dataset ui`) ---
APP_UI_HOST=127.0.0.1
APP_UI_PORT=7860

# --- Pipeline: stage flags (gate which stages 'run-all' executes) ---
APP_RUN_PANELS=true
APP_RUN_BUBBLES=true
APP_RUN_INPAINT=true
APP_RUN_CLEAN=true
APP_RUN_CAPTION=true
# Training is heavy + optional, so it is OFF in `run-all`. Run it explicitly
# with `make-style-dataset train` (see the Stage 6 section below).
APP_RUN_TRAIN=false

# --- Stage 6 (train) — local LoRA training via kohya sd-scripts ---
#
# This stage shells out to a SEPARATE local clone of kohya sd-scripts, run by
# ITS OWN virtualenv (never installed into this project's .venv — its torch /
# numpy / Pillow pins would clobber ours). On a Blackwell GPU (RTX 50xx, sm_120)
# that venv needs a cu128 torch. One-time setup, e.g.:
#
#   git clone https://github.com/kohya-ss/sd-scripts ~/sd-scripts
#   cd ~/sd-scripts && python -m venv venv && . venv/bin/activate
#   pip install torch --index-url https://download.pytorch.org/whl/cu128
#   pip install -r requirements.txt
#
# Then `make-style-dataset doctor` verifies the clone, entrypoint, model paths,
# and that the trainer's torch advertises sm_120.
APP_TRAIN_MODEL_TYPE=sd15          # sd15 | sdxl | flux
APP_TRAIN_BASE_MODEL=              # REQUIRED: base checkpoint (.safetensors) / Flux DiT
APP_TRAIN_SD_SCRIPTS_DIR=/home/serg/sd-scripts
APP_TRAIN_PYTHON=                  # empty -> <sd_scripts_dir>/venv/bin/python
APP_TRAIN_NETWORK_DIM=32
APP_TRAIN_NETWORK_ALPHA=16
APP_TRAIN_LEARNING_RATE=1e-4
APP_TRAIN_MAX_TRAIN_STEPS=1600
APP_TRAIN_RESOLUTION=512           # 512 for sd15; 1024 for sdxl/flux
APP_TRAIN_BATCH_SIZE=1             # keep 1 on 16 GB VRAM
APP_TRAIN_SEED=42
APP_TRAIN_MIXED_PRECISION=fp16     # bf16 recommended for sdxl/flux
APP_TRAIN_GRADIENT_CHECKPOINTING=true
APP_TRAIN_CACHE_LATENTS=true
APP_TRAIN_OUTPUT_NAME=             # empty -> uses APP_TRIGGER_TOKEN
APP_TRAIN_OPTIMIZER_TYPE=AdamW8bit
APP_TRAIN_LR_SCHEDULER=constant
APP_TRAIN_SAVE_EVERY_N_EPOCHS=1    # 0 disables intermediate saves
APP_TRAIN_LOGGING_DIR=             # set to enable TensorBoard logging
APP_TRAIN_CLIP_SKIP=2              # SD 1.5 only
APP_TRAIN_UNET_ONLY=true           # sdxl/flux: train U-Net/DiT only (VRAM-safe)
APP_TRAIN_TEXT_ENCODER_LR=         # sdxl: TE lr when APP_TRAIN_UNET_ONLY=false
APP_TRAIN_FLUX_CLIP_L=             # flux: REQUIRED CLIP-L .safetensors
APP_TRAIN_FLUX_T5XXL=              # flux: REQUIRED T5-XXL .safetensors
APP_TRAIN_FLUX_AE=                 # flux: REQUIRED autoencoder .safetensors
APP_TRAIN_FLUX_BLOCKS_TO_SWAP=18   # flux: 0 disables; 16 GB needs ~8-18, max 35
